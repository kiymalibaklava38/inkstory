# ══════════════════════════════════════════════════════════
# InkStory — Environment Variables
# Copy to .env.local and fill in your values.
# NEVER commit .env.local to version control.
# ══════════════════════════════════════════════════════════

# ── Supabase ──────────────────────────────────────────────
# From: https://supabase.com/dashboard → Project Settings → API
NEXT_PUBLIC_SUPABASE_URL=https://awetmpmlhvxharpsyrfu.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=sb_publishable_va-eXmH7UYxigpt0x-pl7Q_UndHz5si

# ── Anthropic AI ──────────────────────────────────────────
# From: https://console.anthropic.com → API Keys
# NO NEXT_PUBLIC_ prefix — server-side only, never sent to browser
ANTHROPIC_API_KEY=sk-ant-api03-...

# ── Upstash Redis (Rate Limiting) ─────────────────────────
# From: https://console.upstash.com → Create Database → REST API
# Optional: falls back to in-memory rate limiting without these
UPSTASH_REDIS_REST_URL=https://primary-lionfish-73604.upstash.io
UPSTASH_REDIS_REST_TOKEN=gQAAAAAAAR-EAAIncDE1YzhjNWZlZGYwNTI0NTcyOThjNjRjMmQ4N2MzYWUwOXAxNzM2MDQ

# ── Site URL ──────────────────────────────────────────────
NEXT_PUBLIC_SITE_URL=http://localhost:3000
# In production:
# NEXT_PUBLIC_SITE_URL=https://yourdomain.com

# ── Node environment ──────────────────────────────────────
NODE_ENV=development
# In production: NODE_ENV=production

# ── Paddle (Premium — henüz aktif değil) ─────────────────
# Premium sistemi hazır ama kapalı. Kullanıcı kitlesi oluşunca açılacak.
# Paddle hesabı açıldığında buraya ekle: https://paddle.com
# PADDLE_API_KEY=...
# PADDLE_WEBHOOK_SECRET=...
# PADDLE_PRICE_MONTHLY=pri_...
# PADDLE_PRICE_YEARLY=pri_...
# PADDLE_PRICE_LIFETIME=pri_...

# Supabase service role key (webhook için gerekecek)
# Supabase Dashboard → Settings → API → service_role
# SUPABASE_SERVICE_ROLE_KEY=eyJ...
